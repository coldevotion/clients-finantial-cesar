{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": false,
    "paths": {
      "@wa/database": ["../../packages/database/src/index.ts"],
      "@wa/types": ["../../packages/types/src/index.ts"],
      "@wa/bird-client": ["../../packages/bird-client/src/index.ts"],
      "@wa/flow-engine": ["../../packages/flow-engine/src/index.ts"]
    }
  }
}
