# ═══════════════════════════════════════════════════════════════════════════════
# PROVIRED — Variables de entorno
# Copia este archivo a .env y completa los valores reales.
# NUNCA subas .env a git. Solo .env.example va al repositorio.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DB
DATABASE_URL=postgresql://wauser:CHANGE_ME@localhost:5432/wa_campaigns

# Para docker-compose (usado en coolify-compose.yml)
POSTGRES_USER=wauser
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── REDIS ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME_REDIS_PASS@localhost:6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASS

# ─── KAFKA ────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=provired-worker

# ─── CLICKHOUSE ───────────────────────────────────────────────────────────────
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=wa_analytics
CLICKHOUSE_PASSWORD=

# ─── SEGURIDAD ────────────────────────────────────────────────────────────────
# Genera con: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_64_CHAR_HEX_openssl_rand_hex_32

# JWT access token (15min) — genera con: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_JWT_SECRET_min_32_chars

# JWT refresh token (7d) — genera con: openssl rand -hex 64
JWT_REFRESH_SECRET=CHANGE_ME_JWT_REFRESH_SECRET_min_32_chars

# ─── EMAIL / SMTP ─────────────────────────────────────────────────────────────
# Compatible: Gmail, Resend, Mailgun, Postmark, Brevo, SES, etc.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your_smtp_password
MAIL_FROM_NAME=Provired
MAIL_FROM_ADDRESS=noreply@tudominio.com

# ─── BIRD (WhatsApp provider) ─────────────────────────────────────────────────
# El webhook secret se configura en el panel de Bird
BIRD_WEBHOOK_SECRET=CHANGE_ME_BIRD_WEBHOOK_SECRET

# ─── API ──────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── WEB (Next.js) ────────────────────────────────────────────────────────────
# URL pública de la API (sin /api al final)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Activar modo mock para desarrollo sin backend
NEXT_PUBLIC_MOCK_MODE=false

# URL del frontend (usada por la API para links en emails)
WEB_URL=http://localhost:3000

# URL pública del frontend y la API (usadas en coolify-compose.yml)
API_URL=https://api.tudominio.com
WS_URL=wss://api.tudominio.com

# ─── SEED (primer arranque) ───────────────────────────────────────────────────
# El script de seed crea el primer SUPER_ADMIN y el tenant "Provired".
# Solo se ejecuta si no hay usuarios en la base de datos.
SEED_ADMIN_EMAIL=admin@provired.com
SEED_ADMIN_PASSWORD=CHANGE_ME_SUPER_SECURE_PASSWORD
SEED_TENANT_NAME=Provired
SEED_TENANT_SLUG=provired

# ─── COMANDOS ÚTILES ──────────────────────────────────────────────────────────
# Generar ENCRYPTION_KEY:    openssl rand -hex 32
# Generar JWT_SECRET:        openssl rand -hex 64
# Generar JWT_REFRESH_SECRET: openssl rand -hex 64
# Ejecutar migraciones:      pnpm --filter @wa/database run migrate:dev
# Desplegar migraciones:     pnpm --filter @wa/database run migrate:deploy
# Ejecutar seed manual:      pnpm --filter @wa/database run seed
