# ─── DATABASE ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://dev:dev@localhost:5432/wa_campaigns

# ─── REDIS ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── KAFKA ─────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=wa-worker-group

# ─── CLICKHOUSE ────────────────────────────────────────────────────
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=wa_analytics

# ─── SECURITY ──────────────────────────────────────────────────────
# Genera con: openssl rand -hex 32
ENCRYPTION_KEY=change_me_64_char_hex_string_here

# JWT — Genera con: openssl rand -hex 64
JWT_SECRET=change_me_jwt_secret_minimum_32_chars

# ─── EMAIL / SMTP ───────────────────────────────────────────────────
# Compatible con cualquier proveedor SMTP: Gmail, Resend, Mailgun, Postmark, etc.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=yourpassword
MAIL_FROM_NAME=WA Campaigns
MAIL_FROM_ADDRESS=noreply@tudominio.com

# ─── BIRD ──────────────────────────────────────────────────────────
BIRD_WEBHOOK_SECRET=change_me

# ─── API ───────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── WEB ───────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
WEB_URL=http://localhost:3000
